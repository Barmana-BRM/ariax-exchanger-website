# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_API_URL: Frontend API base path (default /ariax-api via Vite proxy).
# For XAMPP on port 80 use: VITE_API_URL=http://localhost/ariax-api
VITE_API_URL="/ariax-api"

# VITE_API_PROXY: Vite dev-server proxy target (default PHP on :8080).
# For XAMPP use: VITE_API_PROXY=http://127.0.0.1
VITE_API_PROXY="http://127.0.0.1:8080"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# KYC_ENCRYPTION_KEY: Server-side secret for encrypting KYC payloads and uploads.
KYC_ENCRYPTION_KEY="CHANGE_ME_TO_A_RANDOM_SECRET"
